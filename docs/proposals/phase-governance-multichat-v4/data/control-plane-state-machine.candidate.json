    {
      "authority": [
        "DIR-01"
      ],
      "from": "READY",
      "gates": [],
      "to": "CLAIMED"
    },
    {
      "authority": [
        "DEV-01..03"
      ],
      "from": "CLAIMED",
      "gates": [],
      "to": "ACTIVE"
    },
    {
      "authority": [
        "DEV-01..03"
      ],
      "from": "ACTIVE",
      "gates": [
        "implementation packet"
      ],
      "to": "FROZEN_FOR_REVIEW"
    },
    {
      "authority": [
        "QA-SEC-01"
      ],
      "from": "FROZEN_FOR_REVIEW",
