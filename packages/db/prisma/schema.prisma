// =============================================================================
// IKEZAKI OS — 統合AI経営OS + LeadMap AI — Prisma schema
//
// 設計方針:
//  - マルチテナント: 原則すべてのモデルが tenantId スカラを持ち @@index([tenantId])。
//    （Tenant への明示リレーションは肥大化を避けるため張らず、アプリ層で分離を強制）
//  - リレーションは「親→子を include で辿る階層」にのみ張る。
//  - 監査ログ/権限/機密ラベルは共通基盤として最初から組み込む。
//  - ベクトルは Float[] で保持（pgvector へ移行可能。MVPは JS でコサイン類似度）。
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // 実行時クエリはプール接続（Supabase: 6543番 / ?pgbouncer=true）を使う。
  url       = env("DATABASE_URL")
  // マイグレーション/イントロスペクションは直接接続（Supabase: 5432番）を使う。
  // ローカルなど非プール環境では DATABASE_URL と同じ値で可。
  directUrl = env("DIRECT_URL")
}

// ============================ Enums ==========================================

enum RoleKey {
  OWNER
  EXECUTIVE
  ADMIN
  DEPARTMENT_MANAGER
  STAFF
  READ_ONLY
  EXTERNAL_EXPERT
  EXTERNAL_PARTNER
  AI_AGENT
  AI_ASSISTANT
}

enum ConfidentialityLabel {
  NORMAL
  INTERNAL
  CONFIDENTIAL
  STRICT_SECRET
  HR_CONFIDENTIAL
  LEGAL_CONFIDENTIAL
  FINANCIAL_CONFIDENTIAL
  CUSTOMER_CONFIDENTIAL
  DINING_RECORD
  EXECUTIVE_ONLY
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum DealStage {
  CONTACT
  HEARING
  PROPOSAL
  QUOTE
  NEGOTIATION
  INTERNAL_REVIEW
  CONTRACT
  DELIVERY
  INVOICE
  FOLLOW_UP
  LOST
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
}

enum LeadStage {
  NEW
  ANALYZED
  DRAFTED
  PENDING_APPROVAL
  READY
  SENT
  OPENED
  CLICKED
  REPLIED
  APPOINTMENT
  NEGOTIATING
  QUOTED
  WON
  LOST
  UNSUBSCRIBED
  EXCLUDED
}

enum DataSource {
  DEMO
  GOOGLE_PLACES
  USER_UPLOAD
  OPENSTREETMAP
  MANUAL
}

enum OutreachStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SENT
  FAILED
}

enum AlertSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  NEEDS_APPROVAL
}

// ============================ 共通基盤 ========================================

model Tenant {
  id        String   @id @default(cuid())
  name      String
  plan      String   @default("mvp")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String    @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String
  name         String
  isAiAgent    Boolean   @default(false)
  isActive     Boolean   @default(true)
  departmentId String?
  avatarColor  String    @default("#6366f1")
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  userRoles       UserRole[]
  employeeProfile EmployeeProfile?

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String
  key         RoleKey
  name        String
  description String   @default("")
  isSystem    Boolean  @default(true)
  permissions String[] // 権限キーの集合（例: "customer:read", "outreach:send"）
  createdAt   DateTime @default(now())

  userRoles UserRole[]

  @@unique([tenantId, key])
  @@index([tenantId])
}

model Permission {
  id          String @id @default(cuid())
  key         String @unique
  category    String
  description String
}

model UserRole {
  id       String   @id @default(cuid())
  tenantId String
  userId   String
  roleId   String
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([tenantId])
}

model Department {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  managerId String?
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model EmployeeProfile {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String   @unique
  employeeCode String
  title        String?
  hiredAt      DateTime?
  employment   String   @default("正社員")
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model FileObject {
  id           String   @id @default(cuid())
  tenantId     String
  key          String // S3 オブジェクトキー（private by default）
  filename     String
  mimeType     String
  sizeBytes    Int      @default(0)
  label        ConfidentialityLabel @default(INTERNAL)
  uploadedById String?
  entityType   String?
  entityId     String?
  createdAt    DateTime @default(now())

  @@index([tenantId])
}

model Tag {
  id       String @id @default(cuid())
  tenantId String
  name     String
  color    String @default("#64748b")

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Comment {
  id         String   @id @default(cuid())
  tenantId   String
  entityType String
  entityId   String
  authorId   String?
  body       String
  createdAt  DateTime @default(now())

  @@index([tenantId, entityType, entityId])
}

model Notification {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  title     String
  body      String   @default("")
  severity  AlertSeverity @default(INFO)
  link      String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([tenantId, userId])
}

model ApprovalRequest {
  id          String         @id @default(cuid())
  tenantId    String
  type        String // 例: "outreach_send", "quote_issue", "contract_sign"
  title       String
  summary     String         @default("")
  entityType  String
  entityId    String
  requestedById String?
  requestedForAction String? // ApprovalAction（shared/approval.ts）
  assigneeRole RoleKey?
  approverRoleRequired RoleKey?
  riskLevel   AlertSeverity  @default(MEDIUM)
  reason      String   @default("")
  payload     Json?
  payloadBefore Json?
  payloadAfter Json?
  status      ApprovalStatus @default(PENDING)
  decidedById String?
  decidedAt   DateTime?
  decisionNote String?
  expiresAt   DateTime?
  auditLogId  String?
  createdAt   DateTime       @default(now())

  @@index([tenantId, status])
  @@index([tenantId, requestedForAction])
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  actorId     String?
  actorType   String   @default("user") // user | ai_agent | system
  action      String // create | update | delete | approve | export | login | ai_run ...
  entityType  String
  entityId    String?
  summary     String   @default("")
  metadata    Json?
  ip          String?
  createdAt   DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, entityType, entityId])
}

model DataAccessLog {
  id         String   @id @default(cuid())
  tenantId   String
  actorId    String?
  actorType  String   @default("user")
  entityType String
  entityId   String?
  label      ConfidentialityLabel @default(NORMAL)
  action     String   @default("read") // read | ai_reference | location_view | recording_view | export | external_share | confidential_view
  purpose    String   @default("")
  policyDecision String? // allow | deny
  consentGrantId String?
  sensitiveReasonId String?
  aiAgentId  String?
  llmCallLogId String?
  ip         String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, action])
  @@index([tenantId, entityType, entityId])
}

model ApiKey {
  id         String   @id @default(cuid())
  tenantId   String
  name       String
  provider   String
  hashedKey  String
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([tenantId])
}

model IntegrationConnection {
  id         String   @id @default(cuid())
  tenantId   String
  provider   String // gmail | outlook | line | slack | accounting | ...
  status     String   @default("disconnected")
  isMock     Boolean  @default(true)
  config     Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  syncLogs IntegrationSyncLog[]

  @@index([tenantId])
}

model IntegrationSyncLog {
  id           String   @id @default(cuid())
  tenantId     String
  connectionId String
  status       String
  itemsSynced  Int      @default(0)
  message      String   @default("")
  createdAt    DateTime @default(now())

  connection IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model SystemSetting {
  id        String   @id @default(cuid())
  tenantId  String
  key       String
  value     Json
  updatedAt DateTime @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId])
}

// ============================ セキュリティ ====================================

model AccessPolicy {
  id          String   @id @default(cuid())
  tenantId    String
  roleKey     RoleKey
  resource    String
  actions     String[] // read create update delete approve export ai_read external_send
  maxLabel    ConfidentialityLabel @default(INTERNAL)
  createdAt   DateTime @default(now())

  @@index([tenantId])
}

model DataMaskingRule {
  id        String   @id @default(cuid())
  tenantId  String
  field     String // name | email | phone | address | health | family
  strategy  String   @default("partial") // partial | full | hash
  enabled   Boolean  @default(true)

  @@index([tenantId])
}

model ConsentRecord {
  id         String   @id @default(cuid())
  tenantId   String
  subject    String // メール/電話など
  channel    String // email | line | sms
  consent    Boolean  @default(false)
  source     String   @default("manual")
  note       String   @default("")
  createdAt  DateTime @default(now())

  @@index([tenantId, subject])
}

model SuppressionList {
  id        String   @id @default(cuid())
  tenantId  String
  channel   String   @default("email")
  value     String // 配信停止対象（メール/ドメイン/電話）
  reason    String   @default("")
  createdAt DateTime @default(now())

  @@unique([tenantId, channel, value])
  @@index([tenantId])
}

model RetentionPolicy {
  id        String @id @default(cuid())
  tenantId  String
  entity    String
  days      Int
  enabled   Boolean @default(true)

  @@index([tenantId])
}

model ExportJob {
  id         String   @id @default(cuid())
  tenantId   String
  requestedById String?
  scope      String // customers | leads | audit | knowledge ...
  format     String   @default("csv")
  status     String   @default("queued")
  fileKey    String?
  createdAt  DateTime @default(now())

  @@index([tenantId])
}

model DeleteRequest {
  id         String   @id @default(cuid())
  tenantId   String
  subject    String
  scope      String
  status     ApprovalStatus @default(PENDING)
  requestedById String?
  createdAt  DateTime @default(now())

  @@index([tenantId])
}

// ============================ CRM ============================================

model Customer {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  industry     String?
  rank         String   @default("B") // A/B/C/D
  ownerId      String?
  phone        String?
  email        String?
  address      String?
  website      String?
  status       String   @default("active")
  label        ConfidentialityLabel @default(CUSTOMER_CONFIDENTIAL)
  satisfaction Int?     // 0-100
  churnRisk    Int?     // 0-100
  nextContactAt DateTime?
  lastContactAt DateTime?
  notes        String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contacts       Contact[]
  deals          Deal[]
  timelineEvents CustomerTimelineEvent[]
  insights       CustomerInsight[]
  interactions   CustomerInteraction[]
  complaints     CustomerComplaint[]
  invoices       Invoice[]

  @@index([tenantId])
  @@index([tenantId, name])
}

model Contact {
  id         String   @id @default(cuid())
  tenantId   String
  customerId String
  name       String
  title      String?
  email      String?
  phone      String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model CustomerTimelineEvent {
  id         String   @id @default(cuid())
  tenantId   String
  customerId String
  type       String // email | line | call | meeting | deal | quote | invoice | complaint | ai | task
  title      String
  body       String   @default("")
  actorId    String?
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId, customerId, occurredAt])
}

model CustomerInteraction {
  id         String   @id @default(cuid())
  tenantId   String
  customerId String
  channel    String
  direction  String   @default("outbound")
  summary    String
  occurredAt DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId, customerId])
}

model CustomerInsight {
  id           String   @id @default(cuid())
  tenantId     String
  customerId   String
  needs        String   @default("")
  concerns     String   @default("")
  priceReaction String  @default("")
  nextProposal String   @default("")
  churnRisk    Int      @default(0)
  confidence   Float    @default(0.6)
  ngWords      String[]
  citations    Json?
  generatedBy  String   @default("FakeLLM")
  createdAt    DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId, customerId])
}

model CustomerComplaint {
  id         String   @id @default(cuid())
  tenantId   String
  customerId String
  title      String
  severity   AlertSeverity @default(MEDIUM)
  status     String   @default("open")
  body       String   @default("")
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId, customerId])
}

model CustomerRankHistory {
  id         String   @id @default(cuid())
  tenantId   String
  customerId String
  fromRank   String
  toRank     String
  reason     String   @default("")
  createdAt  DateTime @default(now())

  @@index([tenantId, customerId])
}

// ============================ 案件・営業 ======================================

model Deal {
  id           String    @id @default(cuid())
  tenantId     String
  customerId   String
  title        String
  ownerId      String?
  stage        DealStage @default(CONTACT)
  amount       Decimal   @default(0) @db.Decimal(14, 2)
  cost         Decimal   @default(0) @db.Decimal(14, 2)
  probability  Int       @default(30) // 0-100
  expectedCloseAt DateTime?
  nextAction   String    @default("")
  nextActionAt DateTime?
  competitor   String?
  lostReason   String?
  source       String    @default("manual") // manual | leadmap
  leadId       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  customer     Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  stageHistory DealStageHistory[]
  activities   SalesActivity[]
  quotes       Quote[]
  proposals    Proposal[]

  @@index([tenantId, stage])
  @@index([tenantId, customerId])
}

model DealStageHistory {
  id        String    @id @default(cuid())
  tenantId  String
  dealId    String
  fromStage DealStage?
  toStage   DealStage
  note      String    @default("")
  changedById String?
  createdAt DateTime  @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([tenantId, dealId])
}

model SalesActivity {
  id         String   @id @default(cuid())
  tenantId   String
  dealId     String?
  customerId String?
  type       String // call | visit | email | demo | followup
  summary    String
  ownerId    String?
  occurredAt DateTime @default(now())

  deal Deal? @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([tenantId])
}

model SalesPipelineStage {
  id       String @id @default(cuid())
  tenantId String
  key      String
  name     String
  order    Int

  @@index([tenantId])
}

model Proposal {
  id        String   @id @default(cuid())
  tenantId  String
  dealId    String
  title     String
  body      String   @default("")
  status    String   @default("draft")
  createdAt DateTime @default(now())

  deal  Deal           @relation(fields: [dealId], references: [id], onDelete: Cascade)
  files ProposalFile[]

  @@index([tenantId])
}

model ProposalFile {
  id         String @id @default(cuid())
  tenantId   String
  proposalId String
  fileKey    String
  filename   String

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model SalesReport {
  id        String   @id @default(cuid())
  tenantId  String
  period    String
  summary   String
  metrics   Json?
  createdAt DateTime @default(now())

  @@index([tenantId])
}

// ============================ 見積・契約・請求 ================================

model Quote {
  id          String   @id @default(cuid())
  tenantId    String
  dealId      String?
  customerId  String?
  number      String
  title       String
  status      String   @default("draft") // draft | pending_approval | approved | sent | accepted | rejected
  subtotal    Decimal  @default(0) @db.Decimal(14, 2)
  cost        Decimal  @default(0) @db.Decimal(14, 2)
  discountRate Decimal @default(0) @db.Decimal(5, 2)
  taxRate     Decimal  @default(10) @db.Decimal(5, 2)
  total       Decimal  @default(0) @db.Decimal(14, 2)
  grossMargin Decimal  @default(0) @db.Decimal(14, 2)
  grossMarginRate Decimal @default(0) @db.Decimal(5, 2)
  validUntil  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deal      Deal?           @relation(fields: [dealId], references: [id], onDelete: SetNull)
  lineItems QuoteLineItem[]

  @@index([tenantId])
}

model QuoteLineItem {
  id        String  @id @default(cuid())
  tenantId  String
  quoteId   String
  name      String
  quantity  Decimal @default(1) @db.Decimal(12, 2)
  unitPrice Decimal @default(0) @db.Decimal(14, 2)
  unitCost  Decimal @default(0) @db.Decimal(14, 2)
  amount    Decimal @default(0) @db.Decimal(14, 2)

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Contract {
  id          String   @id @default(cuid())
  tenantId    String
  customerId  String?
  dealId      String?
  number      String
  title       String
  status      String   @default("draft") // draft | active | expiring | ended | terminated
  startDate   DateTime?
  endDate     DateTime?
  renewalDate DateTime?
  autoRenew   Boolean  @default(false)
  value       Decimal  @default(0) @db.Decimal(14, 2)
  fileKey     String?
  label       ConfidentialityLabel @default(LEGAL_CONFIDENTIAL)
  createdAt   DateTime @default(now())

  clauses ContractClause[]
  risks   ContractRisk[]

  @@index([tenantId])
}

model ContractClause {
  id         String @id @default(cuid())
  tenantId   String
  contractId String
  heading    String
  body       String
  important  Boolean @default(false)

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model ContractRisk {
  id          String        @id @default(cuid())
  tenantId    String
  contractId  String
  description String
  severity    AlertSeverity @default(MEDIUM)
  recommendation String     @default("")
  expertNeeded Boolean      @default(false)
  createdAt   DateTime      @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Invoice {
  id         String        @id @default(cuid())
  tenantId   String
  customerId String?
  dealId     String?
  number     String
  status     InvoiceStatus @default(DRAFT)
  issueDate  DateTime?
  dueDate    DateTime?
  subtotal   Decimal       @default(0) @db.Decimal(14, 2)
  taxAmount  Decimal       @default(0) @db.Decimal(14, 2)
  total      Decimal       @default(0) @db.Decimal(14, 2)
  paidAmount Decimal       @default(0) @db.Decimal(14, 2)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  customer   Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lineItems  InvoiceLineItem[]
  payments   Payment[]
  receivable Receivable?

  @@index([tenantId, status])
}

model InvoiceLineItem {
  id        String  @id @default(cuid())
  tenantId  String
  invoiceId String
  name      String
  quantity  Decimal @default(1) @db.Decimal(12, 2)
  unitPrice Decimal @default(0) @db.Decimal(14, 2)
  amount    Decimal @default(0) @db.Decimal(14, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Payment {
  id        String   @id @default(cuid())
  tenantId  String
  invoiceId String
  amount    Decimal  @db.Decimal(14, 2)
  method    String   @default("bank")
  paidAt    DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Receivable {
  id         String   @id @default(cuid())
  tenantId   String
  invoiceId  String   @unique
  amount     Decimal  @db.Decimal(14, 2)
  dueDate    DateTime?
  status     String   @default("open") // open | overdue | collected
  riskScore  Int      @default(0)
  createdAt  DateTime @default(now())

  invoice    Invoice              @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  reminders  CollectionReminder[]

  @@index([tenantId, status])
}

model CollectionReminder {
  id           String   @id @default(cuid())
  tenantId     String
  receivableId String
  draftMessage String
  status       String   @default("draft")
  createdAt    DateTime @default(now())

  receivable Receivable @relation(fields: [receivableId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ============================ 会計・財務 ======================================

model Account {
  id       String @id @default(cuid())
  tenantId String
  code     String
  name     String
  type     String // asset | liability | equity | revenue | expense

  lines JournalEntryLine[]

  @@index([tenantId])
}

model JournalEntry {
  id        String   @id @default(cuid())
  tenantId  String
  date      DateTime
  memo      String   @default("")
  source    String   @default("manual")
  createdAt DateTime @default(now())

  lines JournalEntryLine[]

  @@index([tenantId, date])
}

model JournalEntryLine {
  id        String  @id @default(cuid())
  tenantId  String
  entryId   String
  accountId String
  debit     Decimal @default(0) @db.Decimal(14, 2)
  credit    Decimal @default(0) @db.Decimal(14, 2)

  entry   JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)

