# =============================================================================
# 369 統合AI経営OS + LeadMap AI — 環境変数サンプル
# このファイルには実値（本物のシークレット）を入れないこと。
# 開発時は `cp .env.example .env` してローカル値を設定する。
# =============================================================================

# --- アプリ ---
NODE_ENV=development
APP_URL=http://localhost:3000
# セッション署名用シークレット（本番では必ず変更・十分なエントロピーを確保）
SESSION_SECRET=dev-only-insecure-session-secret-change-me-0123456789abcdef

# --- データベース (PostgreSQL) ---
# docker-compose 利用時: postgres://app:app@localhost:5432/app369
DATABASE_URL=postgresql://postgres@localhost:5432/app369

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- オブジェクトストレージ (S3互換 / ローカルは MinIO) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=app369
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# --- メール (開発は Mailhog/Mailpit、本番は SendGrid/Resend/SMTP に差し替え) ---
MAIL_PROVIDER=log            # log | smtp | sendgrid | resend
MAIL_FROM="369 OS <no-reply@369.local>"
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
# 外部送信のマスタースイッチ。安全のため既定で無効。
EXTERNAL_SEND_ENABLED=false

# --- LLM Provider 抽象化 ---
# fake | openai | anthropic   （キー未設定/未指定なら自動で fake にフォールバック）
LLM_PROVIDER=fake
LLM_MODEL=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
# 外部LLM送信前のPIIマスキング（既定で有効）
LLM_MASK_PII=true

# --- Embedding Provider ---
# fake | openai
EMBEDDING_PROVIDER=fake
EMBEDDING_MODEL=

# --- Transcription Provider ---
# fake | openai
TRANSCRIPTION_PROVIDER=fake

# --- Maps / Places Provider 抽象化 ---
# demo | google   （キー未設定なら自動で demo にフォールバック）
MAPS_PROVIDER=demo
GOOGLE_MAPS_API_KEY=
# クライアント側地図表示用（公開可・ブラウザに露出する）
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_MAPS_PROVIDER=demo

# --- 外部URLフェッチ（Webサイト解析）の安全設定 ---
FETCH_TIMEOUT_MS=8000
FETCH_MAX_BYTES=2000000
# 許可ドメイン（カンマ区切り、空なら全許可だが内部/予約レンジは常にブロック）
FETCH_ALLOWLIST=
