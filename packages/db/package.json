{
  "name": "@hokko/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "push": "dotenv -e ../../.env -- prisma db push --skip-generate",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "vercel-setup": "node prisma/vercel-setup.mjs",
    "reset": "dotenv -e ../../.env -- prisma migrate reset --force",
    "pretypecheck": "prisma generate",
    "typecheck": "tsc --noEmit",
    "test:integration": "dotenv -e ../../.env -- vitest run --config vitest.integration.config.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hokko/shared": "workspace:*",
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "@hokko/ai": "workspace:*",
    "@hokko/integrations": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^2.4.3",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
