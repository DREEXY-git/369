{
  "name": "ikezaki-os-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "IKEZAKI OS — 統合AI経営OS + LeadMap AI / AI新規開拓OS",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "postinstall": "pnpm --filter @hokko/db generate",
    "dev": "pnpm --filter @hokko/web dev",
    "build": "pnpm db:generate && pnpm --filter @hokko/web build",
    "start": "pnpm --filter @hokko/web start",
    "worker:dev": "pnpm --filter @hokko/worker dev",
    "worker:start": "pnpm --filter @hokko/worker start",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "pnpm -r --workspace-concurrency=1 typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "pnpm --filter @hokko/db generate",
    "db:migrate": "pnpm --filter @hokko/db migrate",
    "db:migrate:deploy": "pnpm --filter @hokko/db migrate:deploy",
    "db:push": "pnpm --filter @hokko/db push",
    "db:seed": "pnpm --filter @hokko/db seed",
    "db:reset": "pnpm --filter @hokko/db reset",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\""
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "prisma", "esbuild"]
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.1.3",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
