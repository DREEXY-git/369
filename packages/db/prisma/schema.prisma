// =============================================================================
// Phase 1-2: コンプラ同意 / ABAC / 機密参照 / イベント連動基盤
//  - すべて tenantId スカラでスコープ（Tenant への明示リレーションは張らない）。
//  - フラットなログ/イベントテーブル。検索用 index を付与。
// =============================================================================

model ConsentPolicy {
  id              String   @id @default(cuid())
  tenantId        String
  key             String // location_tracking | recording | external_llm | expert_share | email_marketing | sms | line | call_center
  purpose         String
  dataType        String   @default("")
  description     String   @default("")
  requiresConsent Boolean  @default(true)
  retentionDays   Int      @default(365)
  version         Int      @default(1)
  active          Boolean  @default(true)
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId])
}

model ConsentGrant {
  id            String    @id @default(cuid())
  tenantId      String
  subjectType   String // employee | customer | contact
  subjectUserId String?
  customerId    String?
  subjectLabel  String    @default("") // 表示用（氏名/メール等）
  policyKey     String
  purpose       String
  status        String    @default("granted") // granted | withdrawn
  version       Int       @default(1)
  source        String    @default("manual")
  note          String    @default("")
  grantedAt     DateTime  @default(now())
  withdrawnAt   DateTime?
  expiresAt     DateTime?
  createdById   String?
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId, policyKey])
  @@index([tenantId, subjectUserId])
  @@index([tenantId, customerId])
}

model SensitiveAccessReason {
  id           String    @id @default(cuid())
  tenantId     String
  actorId      String?
  targetType   String
  targetId     String?
  dataType     String    @default("")
  purpose      String    @default("")
  reason       String
  approvedById String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([tenantId, actorId])
  @@index([tenantId, targetType, targetId])
}

model PolicyDecisionLog {
  id               String               @id @default(cuid())
  tenantId         String
  actorId          String?
  actorType        String               @default("user")
  resource         String // dataType
  action           String
  label            ConfidentialityLabel @default(NORMAL)
  decision         String // allow | deny
  reason           String               @default("")
  policyId         String               @default("abac-v1")
  matchedRules     String[]
  purpose          String               @default("")
  requiredApproval Boolean              @default(false)
  requiredConsent  Boolean              @default(false)
  requiredReason   Boolean              @default(false)
  targetId         String?
  createdAt        DateTime             @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, decision])
}

model DomainEvent {
  id             String    @id @default(cuid())
  tenantId       String
  eventType      String
  aggregateType  String
  aggregateId    String
  actorId        String?
  actorType      String    @default("user")
  payload        Json?
  metadata       Json?
  idempotencyKey String
  status         String    @default("pending") // pending|processing|processed|failed|dead
  failureReason  String?
  retryCount     Int       @default(0)
  occurredAt     DateTime  @default(now())
  processedAt    DateTime?

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, eventType])
  @@index([tenantId, status])
  @@index([aggregateType, aggregateId])
}

model OutboxMessage {
  id            String    @id @default(cuid())
  tenantId      String
  eventId       String
  eventType     String
  topic         String    @default("domain")
  payload       Json?
  status        String    @default("pending") // pending|delivered|failed|dead
  attempts      Int       @default(0)
  nextAttemptAt DateTime  @default(now())
  lastError     String?
  createdAt     DateTime  @default(now())
  deliveredAt   DateTime?

  @@index([tenantId, status, nextAttemptAt])
  @@index([eventId])
}

model WebhookSubscription {
  id          String   @id @default(cuid())
  tenantId    String
  eventType   String // "*" で全イベント
  url         String
  secret      String
  active      Boolean  @default(true)
  description String   @default("")
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, active])
}

model WebhookDelivery {
  id             String    @id @default(cuid())
  tenantId       String
  subscriptionId String
  eventId        String
  eventType      String
  url            String
  status         String    @default("pending") // pending|success|failed
  statusCode     Int?
  attempts       Int       @default(0)
  signature      String    @default("")
  error          String?
  createdAt      DateTime  @default(now())
  deliveredAt    DateTime?

  @@index([tenantId, status])
  @@index([subscriptionId])
}

model LocationAccessLog {
  id                  String   @id @default(cuid())
  tenantId            String
  actorId             String?
  targetUserId        String?
  purpose             String   @default("")
  reason              String   @default("")
  decision            String   @default("allow")
  withinBusinessHours Boolean  @default(true)
  consentStatus       String   @default("")
  ip                  String?
  createdAt           DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, targetUserId])
}

model RecordingAccessLog {
  id            String   @id @default(cuid())
  tenantId      String
  actorId       String?
  recordingId   String?
  meetingId     String?
  purpose       String   @default("")
  reason        String   @default("")
  decision      String   @default("allow")
  consentStatus String   @default("")
  external      Boolean  @default(false)
  ip            String?
  createdAt     DateTime @default(now())

  @@index([tenantId, createdAt])
}

// =============================================================================
// Phase 1-3: JobRun 基盤 / 従業員位置情報（最小縦スライス）
// =============================================================================

model JobRun {
  id             String    @id @default(cuid())
  tenantId       String?
  jobType        String
  status         String    @default("pending") // pending|running|succeeded|failed|dead
  startedAt      DateTime?
  finishedAt     DateTime?
  attempts       Int       @default(0)
  idempotencyKey String?
  payload        Json?
  result         Json?
  error          String?
  actorId        String?
  metadata       Json?
  createdAt      DateTime  @default(now())

  logs JobRunLog[]

  @@index([jobType, status])
  @@index([tenantId, createdAt])
  @@index([status, createdAt])
}

model JobRunLog {
  id        String   @id @default(cuid())
  jobRunId  String
  level     String   @default("info") // info|warn|error
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  jobRun JobRun @relation(fields: [jobRunId], references: [id], onDelete: Cascade)

  @@index([jobRunId, createdAt])
}

model JobSchedule {
  id          String    @id @default(cuid())
  jobType     String    @unique
  everyMs     Int       @default(0)
  cron        String?
  active      Boolean   @default(true)
  description String    @default("")
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  updatedAt   DateTime  @updatedAt
}

model EmployeeLocationLog {
  id                String   @id @default(cuid())
  tenantId          String
  userId            String // 従業員
  lat               Float
  lng               Float
  accuracy          Float?
  address           String   @default("")
  source            String   @default("gps_punch") // gps_punch | route | manual
  withinWorkingHours Boolean @default(true)
  recordedAt        DateTime @default(now())
  createdAt         DateTime @default(now())

  @@index([tenantId, userId, recordedAt])
}

// =============================================================================
// Phase 1-4: Growth Infrastructure（成長イベント台帳 / Marketing OS / DX OS / AI安全）
//  - GrowthEvent は「経営成長イベント台帳」。DomainEvent（システムイベント）とは別物。
//  - 会社の出来事を 売上/利益/工数削減/コスト削減/売上インパクト に接続する。
// =============================================================================

model GrowthEvent {
  id           String   @id @default(cuid())
  tenantId     String
  type         String // marketing.campaign.created | sales.deal.won | dx.automation.completed ...
  category     String // marketing | sales | finance | dx | ai | management | customer
  title        String
  description  String   @default("")
  actorId      String?
  actorType    String   @default("user")
  entityType   String?
  entityId     String?
  // 経営指標への接続
  amount        Decimal? @db.Decimal(16, 2)
  currency      String   @default("JPY")
  revenueImpact Decimal? @db.Decimal(16, 2)
  costSaving    Decimal? @db.Decimal(16, 2)
  timeSavingMinutes Int?
  metric       Json?
  payload      Json?
  domainEventId String?
  occurredAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([tenantId, occurredAt])
  @@index([tenantId, category])
  @@index([tenantId, type])
}

model DXAssessment {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  department  String   @default("")
  summary     String   @default("")
  findings    Json? // 非効率/属人化/重複/紙業務/Excel依存/人手不足/AI化余地 のリスト
  status      String   @default("draft") // draft | reviewed | completed
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  opportunities DXOpportunity[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model DXOpportunity {
  id                        String   @id @default(cuid())
  tenantId                  String
  assessmentId              String?
  title                     String
  problem                   String   @default("")
  solution                  String   @default("")
  estimatedTimeSavingMinutes Int     @default(0)
  estimatedCostSaving       Decimal  @default(0) @db.Decimal(14, 2)
  estimatedRevenueImpact    Decimal  @default(0) @db.Decimal(14, 2)
  difficulty                String   @default("medium") // low | medium | high
  priority                  Int      @default(0)
  status                    String   @default("identified") // identified | planned | in_progress | done | dropped
  createdById               String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @default(now()) @updatedAt

  assessment DXAssessment? @relation(fields: [assessmentId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([tenantId, priority])
}

model AISafetyLog {
  id        String   @id @default(cuid())
  tenantId  String
  actorId   String?
  actorType String   @default("user")
  purpose   String   @default("")
  check     String // injection | pii_mask | tool_permission
  flagged   Boolean  @default(false)
  severity  String   @default("none")
  patterns  String[]
  detail    String   @default("")
  entityType String?
  entityId  String?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, check])
}
